# AStock 智能选股 Agent 课堂演示版环境变量模板
# 使用方法：复制为 .env，然后填写真实密钥。
# 注意：.env 包含敏感信息，不能提交到 GitHub。

# ===== LLM: DeepSeek =====
# DeepSeek API 兼容 OpenAI SDK，所以这里同时填写 DEEPSEEK_* 和 OPENAI_*。
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com

# ===== Web 后端 =====
# 生产环境请换成随机长字符串。
JWT_SECRET=change-this-secret

# ===== 本地/服务器数据路径 =====
TRADINGAGENTS_RESULTS_DIR=./results
TRADINGAGENTS_DATA_DIR=./data
TRADINGAGENTS_CACHE_DIR=./data/cache
TRADINGAGENTS_CHROMA_DB_PATH=./chroma_db
TRADINGAGENTS_LOG_LEVEL=INFO

# ===== 数据源，可选 =====
# 没有 Tushare Token 时，系统会进入课堂稳定模式。
TUSHARE_TOKEN=
FINNHUB_API_KEY=
DASHSCOPE_API_KEY=

# ===== 数据库，可选 =====
# 课堂演示默认不启用 MongoDB/Redis，使用文件缓存即可。
MONGODB_ENABLED=false
REDIS_ENABLED=false
USE_MONGODB_STORAGE=false
