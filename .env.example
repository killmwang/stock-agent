# AStock intelligent stock-agent classroom demo environment template.
# Copy this file to .env and fill real keys. Never commit .env to GitHub.

# ===== LLM: Alibaba Cloud Model Studio Bailian DeepSeek V4-Pro =====
# Bailian exposes DeepSeek through an OpenAI-compatible endpoint, so the
# provider stays "openai" while the base URL points to DashScope/Bailian.
LLM_PROVIDER=openai
DEEP_THINK_LLM=vanchin/deepseek-v4-pro
QUICK_THINK_LLM=vanchin/deepseek-v4-pro
LLM_BACKEND_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=your_dashscope_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# If your Bailian console shows the generic model ID, use this instead:
# DEEP_THINK_LLM=deepseek-v4-pro
# QUICK_THINK_LLM=deepseek-v4-pro

# Market radar reuses QUICK_THINK_LLM and LLM_BACKEND_URL by default.
# Set these only if you want an independent radar model.
# TRENDRADAR_MODEL=vanchin/deepseek-v4-pro
# TRENDRADAR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Official DeepSeek API alternative:
# LLM_PROVIDER=openai
# DEEP_THINK_LLM=deepseek-reasoner
# QUICK_THINK_LLM=deepseek-chat
# LLM_BACKEND_URL=https://api.deepseek.com/v1
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===== Web backend =====
JWT_SECRET=change-this-secret

# ===== Local/server data paths =====
TRADINGAGENTS_RESULTS_DIR=./results
TRADINGAGENTS_DATA_DIR=./data
TRADINGAGENTS_CACHE_DIR=./data/cache
TRADINGAGENTS_CHROMA_DB_PATH=./chroma_db
TRADINGAGENTS_LOG_LEVEL=INFO

# ===== Data sources, optional =====
# Leave TUSHARE_TOKEN empty to use the AKShare replacement mode.
TUSHARE_TOKEN=
FINNHUB_API_KEY=

# ===== Storage, optional =====
# Classroom demo defaults to file-based storage without MongoDB/Redis.
MONGODB_ENABLED=false
REDIS_ENABLED=false
USE_MONGODB_STORAGE=false
