# AStock 智能选股 Agent Web App 环境变量配置
# 复制此文件为 .env 并填写实际值。不要提交真实 .env。

# JWT 密钥，生产环境请更换为强随机字符串
JWT_SECRET=change-this-secret

# DeepSeek 兼容 OpenAI SDK
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com

# 数据源 API，可选
# 没有 Tushare Token 时，课堂稳定模式会自动减少对高权限数据的依赖。
TUSHARE_TOKEN=

# 数据和结果目录
TRADINGAGENTS_RESULTS_DIR=./results
TRADINGAGENTS_DATA_DIR=./data
TRADINGAGENTS_CACHE_DIR=./data/cache
TRADINGAGENTS_CHROMA_DB_PATH=./chroma_db
